---
const principles = [
  'Search memory before planning.',
  'Record decisions with evidence.',
  'Keep generated indexes derivable.',
  'Never store secrets.',
];
---

<section class="section section--ink" id="principles">
  <div class="section__heading">
    <p class="eyebrow eyebrow--light" data-index="III">Operating rules</p>
    <h2>Memory has to stay boring enough to trust.</h2>
    <p>
      The public docs will eventually synthesize the full manifesto. This
      scaffold starts with the rules that shape every future page.
    </p>
  </div>
  <div class="rule-list">
    {
      principles.map((principle) => (
        <div class="rule-list__item">
          <span aria-hidden="true"></span>
          <p>{principle}</p>
        </div>
      ))
    }
  </div>
</section>
