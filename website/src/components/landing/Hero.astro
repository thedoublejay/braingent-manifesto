---
const command = 'git clone https://github.com/thedoublejay/braingent-manifesto.git';
---

<section class="hero">
  <div class="hero__copy">
    <p class="eyebrow" data-index="I">Engineering memory, not another notebook</p>
    <h1>Braingent keeps the receipts for future work.</h1>
    <p class="lede">
      A Git-backed memory system for decisions, setup, repo profiles, agent
      workflows, and retrieval-first planning. Built so humans and AI agents can
      start from context instead of reconstructing history.
    </p>
    <div class="action-row">
      <a class="button button--primary" href="/guides/getting-started/">Read the docs</a>
      <a class="button" href="#setup">Setup path</a>
    </div>
  </div>

  <aside class="hero-art" aria-label="Braingent memory layers">
    <div class="folio">
      <div class="folio__header">
        <span>braingent</span>
        <span>memory stack</span>
      </div>
      <div class="folio__layers">
        <div>
          <span>01</span>
          <strong>Pinned context</strong>
          <small>README, state, preferences</small>
        </div>
        <div>
          <span>02</span>
          <strong>Durable records</strong>
          <small>tasks, decisions, learnings</small>
        </div>
        <div>
          <span>03</span>
          <strong>Retrieved packs</strong>
          <small>focused context before work</small>
        </div>
      </div>
      <button class="command-line" type="button" data-copy-command={command} aria-label="Copy clone command">
        <span>{command}</span>
        <small aria-live="polite">copy</small>
      </button>
    </div>
  </aside>
</section>

<script>
  const copyTargets = document.querySelectorAll<HTMLButtonElement>('[data-copy-command]');

  copyTargets.forEach((button) => {
    const label = button.querySelector('small');
    const defaultText = label?.textContent ?? '';

    button.addEventListener('click', async () => {
      const command = button.dataset.copyCommand;
      if (!command || !label) return;

      try {
        await navigator.clipboard.writeText(command);
        label.textContent = 'copied';
      } catch {
        label.textContent = 'failed';
      }

      window.setTimeout(() => {
        label.textContent = defaultText;
      }, 1600);
    });
  });
</script>
