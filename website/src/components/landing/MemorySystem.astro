---
const layers = [
  {
    title: 'Capture',
    body: 'Turn meaningful work into typed Markdown records with source links, status, and retrieval cues.',
  },
  {
    title: 'Validate',
    body: 'Use frontmatter taxonomy and generated indexes so memory stays searchable and consistent.',
  },
  {
    title: 'Retrieve',
    body: 'Build a focused context pack before planning, reviewing, or changing code.',
  },
];
---

<section class="section" id="system">
  <div class="section__heading">
    <p class="eyebrow" data-index="II">The system</p>
    <h2>Three layers, one source of truth.</h2>
    <p>
      Braingent keeps a small always-read layer, durable evidence records, and
      generated retrieval surfaces that point back to the source files.
    </p>
  </div>
  <div class="system-grid">
    {
      layers.map((layer, index) => (
        <article class="card">
          <span class="card__index">{String(index + 1).padStart(2, '0')}</span>
          <h3>{layer.title}</h3>
          <p>{layer.body}</p>
        </article>
      ))
    }
  </div>
</section>
