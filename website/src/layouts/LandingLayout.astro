---
import '../styles/landing.css';

export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Git-backed engineering memory for humans and AI agents.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://braingent.dev').toString();
const ogImage = new URL('/og-image.webp', Astro.site ?? 'https://braingent.dev').toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://braingent.dev/#website',
      url: 'https://braingent.dev/',
      name: 'Braingent',
      description: 'A shared, Git-backed Markdown memory for AI-assisted engineering.',
      inLanguage: 'en',
    },
    {
      '@type': 'SoftwareApplication',
      '@id': 'https://braingent.dev/#software',
      name: 'Braingent',
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Cross-platform',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      url: 'https://braingent.dev/',
      codeRepository: 'https://github.com/thedoublejay/braingent-manifesto',
      license: 'https://github.com/thedoublejay/braingent-manifesto/blob/main/LICENSE',
      description,
    },
    {
      '@type': 'Person',
      '@id': 'https://josejai.me/#person',
      name: 'JJ Adonis',
      url: 'https://josejai.me',
      sameAs: ['https://github.com/thedoublejay'],
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="theme-color" content="#f4ead5" />
    <meta name="author" content="JJ Adonis" />
    <meta name="generator" content={Astro.generator} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Braingent — A shared memory for AI-assisted engineering" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Braingent" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Braingent — A shared memory for AI-assisted engineering" />
    <link rel="me" href="https://github.com/thedoublejay" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=IBM+Plex+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <slot />
  </body>
</html>
