---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout title="Not found | Braingent">
  <main class="not-found">
    <a class="nav-brand" href="/">
      <img class="mark" src="/braingent_logo.svg" alt="" width="28" height="28" />
      Braingent
    </a>
    <section class="not-found__panel">
      <p class="eyebrow">404</p>
      <h1>That record is not on this shelf.</h1>
      <p>
        The public site is still being assembled. Start from the landing page or
        open the GitHub repository.
      </p>
      <div class="action-row">
        <a class="btn" href="/">Landing</a>
        <a class="btn btn-ghost" href="https://github.com/thedoublejay/braingent-manifesto">GitHub</a>
      </div>
    </section>
  </main>
</LandingLayout>
