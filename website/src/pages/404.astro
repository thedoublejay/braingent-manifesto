---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout title="Not found | Braingent">
  <main class="not-found">
    <a class="wordmark" href="/">Braingent</a>
    <section class="not-found__panel">
      <p class="eyebrow">404</p>
      <h1>That record is not on this shelf.</h1>
      <p>
        The public site is still being assembled. Start from the landing page or
        open the docs index.
      </p>
      <div class="action-row">
        <a class="button button--primary" href="/">Landing</a>
        <a class="button" href="/guides/getting-started/">Docs</a>
      </div>
    </section>
  </main>
</LandingLayout>
