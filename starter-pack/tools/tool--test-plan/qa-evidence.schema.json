{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://braingent.local/tool--test-plan/qa-evidence.schema.json",
  "title": "Braingent QA Evidence Pack",
  "type": "object",
  "required": ["manifest_summary", "rows"],
  "additionalProperties": false,
  "properties": {
    "manifest_summary": {
      "type": "object",
      "required": [
        "evidence_pack_version",
        "generated_at",
        "base_ref",
        "head_ref",
        "total_rows",
        "truncated_rows",
        "dropped_kinds",
        "budget_tokens",
        "used_tokens",
        "confidence_histogram",
        "unsupported_surfaces"
      ],
      "additionalProperties": false,
      "properties": {
        "evidence_pack_version": { "type": "string" },
        "generated_at": { "type": "string" },
        "base_ref": { "type": "string" },
        "head_ref": { "type": "string" },
        "total_rows": { "type": "integer", "minimum": 0 },
        "truncated_rows": { "type": "integer", "minimum": 0 },
        "dropped_kinds": { "type": "array", "items": { "type": "string" } },
        "budget_tokens": { "type": "integer", "minimum": 0 },
        "used_tokens": { "type": "integer", "minimum": 0 },
        "confidence_histogram": {
          "type": "object",
          "required": ["high", "medium", "low", "unresolved"],
          "additionalProperties": false,
          "properties": {
            "high": { "type": "integer", "minimum": 0 },
            "medium": { "type": "integer", "minimum": 0 },
            "low": { "type": "integer", "minimum": 0 },
            "unresolved": { "type": "integer", "minimum": 0 }
          }
        },
        "unsupported_surfaces": { "type": "array", "items": { "type": "string" } }
      }
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_row" }
    },
    "acs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ac_id", "text"],
        "additionalProperties": false,
        "properties": {
          "ac_id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "confidence": {
      "enum": ["high", "medium", "low", "unresolved"]
    },
    "citation": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["file_span", "ac", "graph_edge", "command"] },
        "repo": { "type": "string" },
        "path": { "type": "string" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "ac_id": { "type": "string" },
        "edge_id": { "type": "string" },
        "command": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "file_span" } } },
          "then": { "required": ["repo", "path", "line_start", "line_end"] }
        },
        {
          "if": { "properties": { "kind": { "const": "ac" } } },
          "then": { "required": ["ac_id"] }
        },
        {
          "if": { "properties": { "kind": { "const": "graph_edge" } } },
          "then": { "required": ["edge_id"] }
        },
        {
          "if": { "properties": { "kind": { "const": "command" } } },
          "then": { "required": ["command"] }
        }
      ]
    },
    "evidence_row": {
      "type": "object",
      "required": [
        "row_id",
        "surface",
        "source_kind",
        "symbol",
        "citations",
        "callers",
        "consumers",
        "confidence",
        "truncated",
        "unsupported",
        "token_estimate",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "row_id": { "type": "string", "minLength": 1 },
        "surface": { "enum": ["frontend", "backend"] },
        "source_kind": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string", "minLength": 1 },
        "citations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/citation" }
        },
        "callers": { "type": "array", "items": { "type": "string" } },
        "consumers": { "type": "array", "items": { "type": "string" } },
        "confidence": { "$ref": "#/$defs/confidence" },
        "truncated": { "type": "boolean" },
        "unsupported": { "type": "boolean" },
        "token_estimate": { "type": "integer", "minimum": 0 },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
